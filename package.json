{
  "name": "autoblog",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @autoblog/database db:generate",
    "db:push": "pnpm --filter @autoblog/database db:push",
    "db:seed": "pnpm --filter @autoblog/database db:seed",
    "db:studio": "pnpm --filter @autoblog/database db:studio",
    "db:setup-roles": "pnpm --filter @autoblog/database db:setup-roles",
    "worker:dev": "pnpm --filter @autoblog/worker dev",
    "worker:test-enqueue": "pnpm --filter @autoblog/worker test:enqueue",
    "blog:dev": "pnpm --filter @autoblog/blog dev"
  },
  "devDependencies": {
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "esbuild",
      "sharp"
    ]
  }
}
