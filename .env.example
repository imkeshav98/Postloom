# PostgreSQL (full-privilege, used by admin + worker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postloom?schema=public"

# PostgreSQL (restricted read-only role, used by blog app)
BLOG_DATABASE_URL="postgresql://blog_reader:blog_reader_password@localhost:5432/postloom?schema=public"

# Docker Compose: database passwords
POSTGRES_PASSWORD="postgres"
BLOG_READER_PASSWORD="blog_reader_password"

# Admin app
SESSION_SECRET="change-me-to-a-random-string"
ADMIN_EMAIL="admin@postloom.com"
ADMIN_PASSWORD_HASH=""

# Worker
OPENROUTER_API_KEY="sk-or-..."

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Blog app (per deployment)
BLOG_ID=""
REVALIDATION_SECRET="change-me-to-a-random-string"
